CREATE TABLE auth_session (
    id TEXT NOT NULL PRIMARY KEY,
    sessionId TEXT NOT NULL,
    loginToken TEXT
);

selectSession:
SELECT auth_session.id, auth_session.sessionId, auth_session.loginToken
FROM auth_session
LIMIT 1;

upsertSession:
INSERT OR REPLACE INTO auth_session(id, sessionId, loginToken)
VALUES (?, ?, ?);

clearSession:
DELETE FROM auth_session;
