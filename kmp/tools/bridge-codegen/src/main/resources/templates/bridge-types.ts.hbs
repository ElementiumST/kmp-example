  mode: 'CREATE' | 'EDIT';
  isNote: boolean;
  isDirty: boolean;
  isSaving: boolean;
  errorMessage: string | null;
  showLeaveConfirmation: boolean;
  dismissed: boolean;
  canSave: boolean;
